# Client-side journal passphrase (privacy gate only — not true security).
# Copy this file to .env.local and set your own secret.
VITE_JOURNAL_PASSWORD=my-secret-password

# Supabase (from your project settings)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
